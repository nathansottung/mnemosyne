# Normalize line endings so the repo is byte-stable across Windows/Unix clones.
# Default: let Git detect text vs binary and normalize to LF in the repo.
* text=auto

# Source and docs are always LF in the repo (and in working trees).
*.go   text eol=lf
*.md   text eol=lf
*.html text eol=lf
# JSON (config samples + test fixtures) stays LF so checked-in fixtures are
# byte-stable across platforms — schema_test.go compares a catalog fixture.
*.json text eol=lf

# Windows batch files must stay CRLF or cmd.exe can mis-parse them.
*.bat  text eol=crlf

# The embedded escrow source tarball is binary — never normalize it or go:embed
# would compile a corrupted archive.
*.tar.gz binary
*.gz     binary
